<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="create-ligne-commandes-table" author="foodrush">
        <createTable tableName="ligne_commandes">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="commande_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="plat_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="nom_plat" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="quantite" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="prix_unitaire" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
